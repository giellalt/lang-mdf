ADP_WITH_PX_OR_COP_OR_NOT ;
ADP_AS_SECONDARY_HEAD ; !20250825 oblique forms for secondary head
! 2026-02-17 need oblique possessa with secondary head and then point it to
! ADP_AS_SECONDARY_HEAD


LEXICON ADP_WITH_PX_OR_COP_OR_NOT
 ADP_WITH_PX_OR_NOT ;
 DER/COP ;

LEXICON ADP_WITH_PX_OR_NOT
 K ;
 ADP-WITH-PX ;
 
LEXICON ADP-WITH-PX
 OBLIQUECX-PX-REQUIRES-VOWEL ;
!%>{ЕОØ}н
 OBLIQUECX-PX-REQUIRES-NO-VOWEL ;
!%>т, %>ст

!PO-ABL_ PO-DAT-DEF_ PO_ELA PO-INE_ PO-LAT_ PO-LOC_ PO-PRL_ PO-PRL_ЁНГА PO_КВАЛМА
! ============ !
! Postp lexica !
! ============ !


! This contlex allows for relational word which, otherwise, are open
! to extensive declension
LEXICON PO_
: K ;

!LEXICON PO_КВАЛМА
!: K ;
!! Checking 2018-11-10
!+Pron: OBLIQUECX-PX-REQUIRES-VOWEL ;
!+Pron: OBLIQUECX-PX-REQUIRES-NO-VOWEL ;

LEXICON PO-INE_
+Ine: K_вок ;
! Checking 2018-11-10
+Pron+Ine: OBLIQUECX-PX-REQUIRES-VOWEL ;
+Pron+Ine: OBLIQUECX-PX-REQUIRES-NO-VOWEL	;

!LEXICON PO-ABL_
!+Abl: K_вок ;
!LEXICON PO-DAT-DEF_
!+Dat+Def: K_вок ;
!LEXICON PO_ELA
!+Ela: K_вок ;
LEXICON PO-ILL_ ! коряс:коря 
+Ill:%>с K_вок ;
+Ill:%>{ЕОØ}з OBLIQUECX-PX-osh  ;
!LEXICON PO-LAT_
!+Lat: K_вок ;
!LEXICON PO-LOC_
!+Loc: K_вок ;
!LEXICON PO-PRL_ !!= * @CODE@ ёнга:ёнга
!+Prl: K_вок ;

!LEXICON PO-PRL_ЁНГА !!= * @CODE@ ёнга:ёнга
!+Prl: K_вок ;
!! Checking 2018-11-10
!+Pron+Prl: OBLIQUECX-PX-REQUIRES-VOWEL ;
!+Pron+Prl: OBLIQUECX-PX-REQUIRES-NO-VOWEL    ;

LEXICON PO-PRL_MEL1GE !!= * @CODE@ мельге:мельг{АЕ}
+Prl: K_вок ;
! Checking 2018-11-10
+Prl:%^Е2А OBLIQUECX-PX-REQUIRES-VOWEL ;
+Prl:%^Е2А OBLIQUECX-PX-REQUIRES-NO-VOWEL    ;



!LEXICON PO-SPAT_
!: K ;



